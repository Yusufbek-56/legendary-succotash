{
  "manifest_version": 3,
  "name": "Instagram Volume Controller",
  "version": "1.0.0",
  "description": "Adds a logarithmic volume slider to all Instagram videos with volume sync across posts, reels, and stories.",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.instagram.com/*"
      ],
      "js": [
        "src/config.js",
        "src/styles.js",
        "src/utils.js",
        "src/detection.js",
        "src/native-button.js",
        "src/speed-menu.js",
        "src/scrubber.js",
        "src/volume-slider.js",
        "src/sync.js",
        "src/story-controls.js",
        "src/story-speed.js",
        "src/feed-controls.js",
        "src/reels-controls.js",
        "src/overlay-shield.js",
        "src/video-listeners.js",
        "src/lifecycle.js"
      ],
      "css": [
        "content.css"
      ],
      "type": "module",
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
